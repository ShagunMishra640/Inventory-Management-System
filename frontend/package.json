{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:e2e": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "build": "vite build",
    "cypress:open": "set ELECTRON_RUN_AS_NODE=&& cypress open",
    "cypress:run": "set ELECTRON_RUN_AS_NODE=&& cypress run",
    "cypress:record": "set ELECTRON_RUN_AS_NODE=&& cypress run --record",
    "cypress:verify": "set ELECTRON_RUN_AS_NODE=&& cypress verify",
    "test:e2e": "npm run cypress:run",
    "test:e2e:open": "npm run cypress:open",
    "test:e2e:record": "npm run cypress:record",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.12.0",
    "@tailwindcss/vite": "^4.3.0",
    "axios": "^1.16.1",
    "chart.js": "^4.5.1",
    "cloudinary": "^2.10.0",
    "lucide-react": "^1.17.0",
    "multer": "^2.1.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-qr-code": "^2.0.21",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.16.0",
    "react-toastify": "^11.1.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "cypress": "^15.16.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "start-server-and-test": "^3.0.6",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.12"
  }
}
